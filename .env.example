BINANCE_TESTNET=false

# Создать бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Telegram ID через запятую (узнать: @userinfobot)
TELEGRAM_WHITELIST=your_telegram_id_here

# Шифрование Binance API ключей в БД
# Сгенерировать:
#   docker compose run --rm traider python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Подробные причины, почему сигнал не создан (INFO в консоль). Иначе — только в logs/traider.log (DEBUG)
# VERBOSE_SIGNAL_ANALYSIS=true
