# Binance
# Получить на: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false

# Telegram
# Создать бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Узнать свой ID: @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# PostgreSQL
# Локально через Docker: docker run -d --name traider-db -e POSTGRES_PASSWORD=traider -e POSTGRES_DB=traider -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:traider@localhost:5432/traider

# Параметры торговли
RISK_PER_TRADE=0.05        # 5% депозита на сделку
MAX_OPEN_POSITIONS=3       # максимум открытых позиций
MIN_CONFIDENCE=0.65        # минимальная уверенность модели для сигнала
SIGNAL_TIMEOUT_MINUTES=10  # через сколько минут сигнал сгорает
MIN_RR_RATIO=2.0           # минимальное соотношение риск/прибыль

# Активы для торговли (через запятую)
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# Таймфрейм анализа
TIMEFRAME=15m
